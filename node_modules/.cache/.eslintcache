 sizes. Light weighted this locating pin is properly examined by professionals on various parameters which are preset.</p>\r\n                                          </div>\r\n    \r\n    \r\n                                          <div className='aji'>\r\n                                            <div>\r\n                                            <h4>Features</h4>\r\n                                             <ul className='bro'>\r\n                                              <li>Light weight</li>  \r\n                                              <li>Easy to use</li>\r\n                                              <li>Anti corrosive</li>\r\n                                             </ul>\r\n                                                 </div>\r\n                                          \r\n                                         </div>  \r\n                        </div>\r\n    \r\n                        </div>\r\n                </div>}\r\n\r\n               \r\n            </div>\r\n        </div>\r\n\r\n    \r\n            \r\n           \r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n        </section>\r\n  )\r\n}\r\n\r\nexport default Dr","F:\\sachintools\\src\\Components\\Home\\Award.js",["278","279","280","281"],[],"import React, { Component } from \"react\";\r\nimport './Award.css';\r\n\r\nimport  {Link}  from 'react-router-dom';\r\n\r\nimport img1 from '../../Assets/award1.jpeg';\r\nimport img2 from '../../Assets/award2.jpeg';\r\n\r\n\r\n\r\nconst Award=()=>{\r\nreturn (\r\n    <div className='hold'>\r\n        <h3 className='head'>Our Awards</h3>\r\n     \r\n            <div className='row'>\r\n\r\n            <div className='ra'>\r\n                <img src={img1} className='im1'></img>\r\n            </div>\r\n\r\n\r\n            <div className='rb'>\r\n            <img src={img2} className='im2'></img>\r\n            </div>\r\n\r\n    