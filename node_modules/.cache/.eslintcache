iv>\r\n            \r\n            <div className={classes.row3}>\r\n                <h3>Connect Us</h3>\r\n                <p><a className={classes.lnk} href='mailto:sachintoolsengg@gmail.com'>sachintoolsengg@gmail.com </a><br/> <a className={classes.lnk} href='mailto:sachintoolsengg@yahoo.co.in'>sachintoolsengg@yahoo.co.in</a></p>\r\n                <p><a className={classes.lnk} href='tel:9850089065'>+91 9850089065</a>\r\n                <br/>\r\n                <a className={classes.lnk} href='tel:9850089067'>+91 9850089067</a> </p>\r\n            </div>\r\n            <div className={classes.row4}>\r\n            <iframe src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3784.8394889046153!2d73.8213782738957!3d18.445595571462686!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3bc295fe8218d6dd%3A0x906152e9c20fc0a8!2sKhedekar%20Industrial%20Estate!5e0!3m2!1sen!2sin!4v1695729526345!5m2!1sen!2sin\"  allowfullscreen=\"\" loading=\"lazy\" referrerpolicy=\"no-referrer-when-downgrade\"></iframe>\r\n            </div>\r\n        </div>\r\n        <div className={classes.bottom}>\r\n            <p>Copyright © 2023 Sachin Tools Engineering | Made with <img className={classes.heart} src={hrt} alt='Sachin tools'></img> by Cortica Web Solutions Pvt.Ltd</p>\r\n        </div>\r\n    </div>\r\n    \r\n);\r\n};\r\n\r\n","F:\\sachintools\\src\\Components\\Home\\Patronslider.js",[],[],"F:\\sachintools\\src\\Components\\Home\\Productscards.js",["248","249","250","251"],[],"import React, { Component } from \"react\";\r\nimport classes from './Productscards.module.css';\r\nimport Products from './Products';\r\nimport  {Link}  from 'react-router-dom';\r\n\r\nimport img1 from '../../Assets/corepnproduct.webp';\r\nimport img2 from '../../Assets/trc-GwSjNOuA8-transformed.png';\r\nimport img3 from '../../Assets/grindingworks-transformed.png';\r\nimport img4 from '../../Assets/carbidedead-transformed.png';\r\nimport img5 from '../../Assets/hsscutter-zeNIj-3wqC-transformed.png';\r\nimport img6 from '../../Assets/valveseatadaptedr-transformed.png';\r\nimport img7 from '../../Assets/hobbing-transformed (1).png';\r\nimport img8 from '../../Assets/precisioncomp-transformed.png';\r\nimport img9 from '../../Assets/rest.png';\r\nimport img10 from '../../Assets/industrialcutter-A1V0qoA-z-transformed.png';\r\n\r\nimport SProduct6 from '../../Assets/diamond.webp';\r\n\r\nconst Productscards=()=>{\r\nreturn (\r\n    <div className={classes.hold}>\r\n        <h3 className={classes.head}>Our Products</h3>\r\n     \r\n            <div className={classes.row}>\r\n\r\n            <div>\r\n            <Link className={classes.lnkp} to='/corepin'> <Products img={img1}  head='CORE PINS'  text='READ MORE'></Products> </Link>\r\n            </div>\r\n            <div>\r\n            <Link className={classes.lnkp} to='/Dr'>  <Products img={SProduct6}  head='DIAMOND PINS & ROUND PINS' text='READ MORE'></Products></Link>\r\n            </div>\r\n            <div>\r\n            <Link className={classes.lnkp} to='/Ttc'>  <Products img={img2} head='TOOL ROOM COMPONENT'text='READ MORE' ></Products></Link>\r\n            </div>\r\n          {/*\r\n            <div>\r\n            <Link className={classes.lnkp} to='/Grading'>   <Products  head='GRINDING WORKS' text='READ MORE'></Products></Link>\r\n            </div>\r\n*/}\r\n            <div>\r\n            <Link className={classes.lnkp} to='/Cdc'>   <Products img={img4} head='CARBIDE DEAD CENTERS' text='READ MORE'></Products></Link>\r\n            </div>\r\n            {/*<div>\r\n            <Link className={classes.lnkp} to='/Cahrc'>  <Products img={img5} head='CARBIDE AND HSS CUTTERS RESHARPENING' text='READ MORE'></Products></Link>\r\n</div>*/}\r\n            \r\n            </div>\r\n\r\n\r\n            <div className={classes.row}>\r\n\r\n            <div>\r\n            <Link className={classes.lnkp} to='/vsa'>  <Products img={img6} head='VALVE SEAT ADAPTER' text='READ MORE' ></Products></Link>\r\n            </div>\r\n            <div>\r\n            <Link className={classes.lnkp} to='/Hfa'>  <Products img={img7} head='HOBBING FIXTURE SLEEVES' text='READ MORE' ></Products></Link>\r\n            </div>\r\n            <div>\r\n            <Link className={classes.lnkp} to='/Pc'>  <Products img={img8} head='PERCISION COMPONENT' text='READ MORE'></Products></Link>\r\n            </div>\r\n            <div>\r\n            <Link className={classes.lnkp} to='/Restpad'>  <Products img={img9} head='REST PAD' text='READ MORE'></Products></Link>\r\n            </div>\r\n            {/*\r\n            <div>\r\n            <Link className={classes.lnkp} to='/Industrials'>  <Products img={img10} head='INDUSTRIAL CUTTERS' text='READ MORE' ></Products></Link>\r\n</div> */}\r\n            </div>\r\n\r\n    </div>\r\n)\r\n};\r\n\r\nexport default Productscards;","F:\\sachintools\\src\\Components\\Home\\Cpasm.js",["252","253","254","255","256","257"],[],"import classes from './Cpasm.module.css';\r\nimport { FaCheck} from 'react-icons/fa';\r\n\r\n\r\nimport img1 from '../../Assets/customs (1).png';\r\nimport img2 from '../../Assets/distribution.png';\r\nimport img3 from '../../Assets/wallet.png';\r\nimport img4 from '../../Assets/cus.png';\r\nimport img5 from '../../Assets/delivery.png';\r\nimport img6 from '../../Assets/money.png';\r\n\r\n\r\nconst Cpasm=()=>{\r\n    return(\r\n\r\n<div className={classes.main}>\r\n\r\n<div className={classes.hold}><br></br><br></br>\r\n        <h1 className={classes.head}>Our Assurance</h1>\r\n        <br></br>\r\n        <center>     \r\n            <div className={classes.row}>\r\n\r\n            <div>\r\n            <img src={img4} className={classes.img}/>\r\n            <h4 className={classes.heading}>Customize Packing</h4>   \r\n            <h6 className={classes.heading1}>Available &nbsp;  <FaCheck className={classes.ic} /></h6> \r\n            </div>\r\n\r\n\r\n            <div>\r\n            <img src={img6} className={classes.img}/>\r\n            <h4 className={classes.heading}>Payment Accepted</h4>   \r\n            <h5 className={classes.heading1}>Cash | DD | Credit Card | Cheque &nbsp;   <FaCheck className={classes.ic} /></h5> \r\n            </div>\r\n\r\n        \r\n            <div>\r\n            <img src={img5} className={classes.img}/>\r\n            <h4 className={classes.heading}>Shipment Mode</h4>   \r\n            <h5 className={classes.heading1}>By Road &nbsp;   <FaCheck className={classes.ic} /></h5>  \r\n            </div>\r\n\r\n            \r\n</div>\r\n</center>\r\n\r\n\r\n</div>\r\n\r\n</div>\r\n\r\n    )\r\n};\r\n\r\n\r\nexport default Cpasm;","F:\\sachintools\\src\\Components\\Home\\Counter.js",["258"],[],"import React from 'react';\r\nimport { useEffect, useRef, useState } from 'react';\r\nimport classes from './Counter.module.css';\r\n\r\n\r\n\r\nconst Num = ({ end = 10 }) => {\r\n    const [state, setState] = useState(null);\r\n    const ref = useRef(0);\r\n\r\n    const accumulator = end / 200;\r\n\r\n    const updatecounterState = () => {\r\n        if (ref.current < end) {\r\n            const result = Math.ceil(ref.current + accumulator);\r\n\r\n            if (result > end) return setState(end);\r\n            setState(result);\r\n            ref.current = result;\r\n        }\r\n        setTimeout(updatecounterState, 1000)\r\n    };\r\n\r\n    useEffect(() => {\r\n        let isMounted = true;\r\n        if (isMounted) { updatecounterState() };\r\n\r\n        return () => isMounted = false;\r\n    }, [end]);\r\n\r\n\r\n\r\n    return <div>\r\n        <div className={classes.container}>\r\n            <div className={classes.hold}>\r\n            \r\n                <div><span className={classes.num}>{state+15}+</span></div>\r\n                <div><span className={classes.k}>Years Of Experience</span></div>\r\n            \r\n            </div>\r\n            <div className={classes.hold1}>\r\n            \r\n                <div><span className={classes.num}>{state+45}+</span></div>\r\n                <div><span className={classes.k}>Number of Clients</span></div>\r\n                \r\n            </div>\r\n    <div className={classes.hold1}>\r\n     \r\n    <div><span className={classes.num}>{state+5}+</span></div>\r\n    <div><span className={classes.k}>Number of Employees</span></div>\r\n    \r\n</div>\r\n\r\n        </div >\r\n \r\n    </div>\r\n};\r\n\r\nexport default Num;","F:\\sachintools\\src\\Components\\Home\\Wwr.js",["259","260","261","262","263","264","265"],[],"import React from 'react'\r\nimport classes from './Wwr.module.css';\r\n\r\n\r\n\r\n\r\n\r\nimport b from '../../Assets/tools1.jpeg';\r\n\r\nimport tech from '../../Assets/quality.png';\r\nimport set from '../../Assets/setting.png';\r\nimport cert from '../../Assets/artificial-intelligence.png';\r\nimport support from '../../Assets/customer-support.png';\r\nimport pack from '../../Assets/pack.png';\r\nimport hold from '../../Assets/hold.png';\r\n\r\nconst Wwr = () => {\r\n  return (\r\n    \r\n    <div className={classes.para1}>\r\n        <h1 className={classes.Aa}>Why Choose Us !</h1>\r\n       <div className={ classes.main}>\r\n       \r\n       <div className={ classes.hold}>\r\n          \r\n         \r\n            <div>\r\n          \r\n          \r\n         \r\n          <div className={classes.card}>\r\n            \r\n          <div className={classes.c1}>\r\n                <img src={cert} className={classes.am}></img>\r\n                <h3  className={classes.h3}>High Technology</h3>\r\n                \r\n                <p>Process and customer centric driven with transparent results for last 25+ years.</p>\r\n            </div>\r\n            <div className={classes.c1}>\r\n              \r\n                <img src={tech} className={classes.am}></img>\r\n                <h3 className={classes.h3}>Certification</h3>\r\n                <p>Green Channel Manufactureing, Baught Out, Longest Association.</p>\r\n                \r\n            </div>\r\n            <div className={classes.c1}>\r\n                <img src={set} className={classes.am}></img>\r\n                <h3 className={classes.h3}>Awarded For</h3>\r\n                <p>Quality, Experience, Reliability.</p>\r\n            </div>\r\n            <div className={classes.c1}>\r\n                <img src={support} className={classes.am}></img>\r\n                <h3 className={classes.h3}>24/7 Support</h3>\r\n                <p>Customized customer solutions based on understanding.</p>\r\n            </div>\r\n          </div>\r\n       </div>\r\n       </div>\r\n       <div className={classes.big}>\r\n       <div className={classes.left}>\r\n       <div className={classes.A}>\r\n            <span>Our Company</span>\r\n          </div>\r\n          <div><h2 className={classes.paraL}>Its commitment to service is built on a culture of <span className={classes.ceo}>Trust, \r\n                                     Responsibility and Accountability</span>.</h2></div>\r\n\r\n                <div>\r\n                 <p className={classes.paraS}><span className={classes.ceo}>Sachin Tools Engineering, founded in 1998</span>                                                                                                                                                                              , is a prominent manufacturer and provider of a diverse range of products such as Core Pins, Precision Components, and more.</p>\r\n                 </div>\r\n                 <div>\r\n                 <p className={classes.paraS}>We've earned a distinct market position under <span className={classes.ceo}>Mr. Santosh Sharma's leadership </span>, thanks to strong management and industry knowledge, and company's ultimate goal of providing quality services.</p>\r\n                 </div>\r\n                 <center>\r\n                 <div className={classes.two}>\r\n                 \r\n                 <div className={classes.dg}>\r\n                    <img src={pack} className={classes.B}></img>\r\n                    <h4>Secure Packing</h4>\r\n                    \r\n                 </div>\r\n                 <div className={classes.dg}>\r\n                    <img src={hold} className={classes.B}></img>\r\n                    <h4>Delivery unlimited</h4>\r\n                    \r\n                 </div>\r\n                 \r\n                 </div>\r\n                 </center>\r\n                 </div>\r\n                 <div className={classes.flex}>\r\n                 <center>  <img src={b} className={classes.A2}></img> </center> \r\n                 </div>\r\n                 </div>\r\n          </div>\r\n          </div>        \r\n  )\r\n}\r\nexport default Wwr;","F:\\sachintools\\src\\Components\\Contact\\Cont.js",["266","267","268","269","270"],[],"import React, { useRef } from 'react';\r\nimport emailjs from '@emailjs/browser';\r\n\r\n\r\nimport classes from './Contact.module.css';\r\nimport contact from '../../Assets/contact.jpg';\r\nimport visit from '../../Assets/visit.png';\r\nimport phone from '../../Assets/phone.png';\r\nimport mail from '../../Assets/mail.png';\r\n\r\n\r\n\r\nconst Cont = () => {\r\n  const form = useRef();\r\n\r\n  const sendEmail = (e) => {\r\n    e.preventDefault();\r\n\r\n    emailjs.sendForm('service_mhvffth', 'template_s6bs7ep', form.current, 'djycP38Xc1pOCIr4y')\r\n      .then((result) => {\r\n          console.log(result.text);\r\n      }, (error) => {\r\n          console.log(error.text);\r\n      });\r\n  };\r\n  return (\r\n    <div className={classes.Cmain}> \r\n      \r\n      <div className={classes.top}>\r\n        <div>\r\n        <img src={contact} className={classes.image}></img>\r\n        </div>\r\n        <div className={classes.flex}>\r\n        <div className={classes.para1}>\r\n          <h1>Contact Us</h1>\r\n          <p>Need an Expert?<br/>\r\n          You are more than welcome to leave your <br></br>contact info and we will be in touch shortly</p>\r\n          </div>\r\n          <div className={classes.left}>\r\n          <form ref={form} onSubmit={sendEmail} className={classes.bg}>\r\n              <label> Frist Name</label><br></br>\r\n              <input type='text'name=\"name\" ></input><br></br><br></br>\r\n              <label> Last Name</label><br></br>\r\n              <input type='text' name=\"Lname\" ></input><br></br><br></br>\r\n              <label> Email address</label><br></br>\r\n              <input type='text'name=\"email\" ></input><br></br><br></br>\r\n              <label>Comments</label><br></br>\r\n              <textarea cols='46' rows='10' name=\"message\">\r\n\r\n              </textarea><br></br>\r\n              <div>\r\n                <button type=\"submit\" value=\"Send\" className={classes.btn}>SEND</button>\r\n              </div>\r\n\r\n\r\n            </form>\r\n          </div>\r\n         </div>\r\n      </div>\r\n      <div className={classes.add}>\r\n        <div className={classes.frist}>\r\n          <div className={classes.A1}>\r\n          <img src={visit} className={classes.vicon}></img>\r\n          <h3>Visit Us</h3>\r\n          <p className={classes.visit}>S. NO. 38/1, KHEDEKAR INDUSTRIAL<br></br> ESTATE, BEHIND PARI CO.,<br></br> NARHEGAON, PUNE -411041</p>\r\n          </div>\r\n        </div>\r\n        <div className={classes.second}>\r\n          <div className={classes.A2}>\r\n          <img src={phone} className={classes.picon}></img>\r\n          <h3>Call Us</h3>\r\n          <p><a href='tel:9850089065'>+919850089065</a></p>\r\n          <p><a href='tel:9850089067'>+919850089067</a></p>\r\n     \r\n          </div>\r\n\r\n        </div>\r\n\r\n\r\n        <div className={classes.third}>\r\n          <div className={classes.A3}>\r\n          <img src={mail}className={ classes.micon}></img>\r\n          <h3>Message Us</h3>\r\n          <p><a href='mailto:sachintoolsengg@gmail.com'>sachintoolsengg@gmail.com</a></p>\r\n          <p><a href='mailto:sachintoolsengg@ya